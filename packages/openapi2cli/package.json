{
  "name": "@tronsfey/openapi2cli",
  "version": "1.0.17",
  "description": "Generate or proxy any OpenAPI 3.x spec as a typed Commander.js CLI, with shell completion",
  "main": "dist/index.js",
  "bin": {
    "openapi2cli": "./bin/openapi2cli",
    "ucli": "./bin/openapi2cli"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "keywords": [
    "openapi",
    "cli",
    "generator",
    "commander",
    "typescript",
    "swagger",
    "codegen",
    "oas3",
    "rest"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tronsfey928/openapi2cli.git"
  },
  "homepage": "https://github.com/tronsfey928/openapi2cli#readme",
  "bugs": {
    "url": "https://github.com/tronsfey928/openapi2cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/templates/**/*.hbs\" dist/",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --testPathIgnorePatterns=tests/integration",
    "test:e2e": "jest tests/integration/express-server.test.ts --testTimeout=180000",
    "test:proxy-e2e": "jest tests/integration/proxy-e2e.test.ts --testTimeout=180000",
    "test:real-service": "npm run test:e2e && npm run test:proxy-e2e",
    "test:integration": "jest tests/integration/github.test.ts --testTimeout=180000",
    "test:all": "jest --testTimeout=180000",
    "generate:examples": "ts-node scripts/generate-example.ts",
    "test:coverage": "jest --coverage --testPathIgnorePatterns=tests/integration",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run lint && npm test && npm run build && npm run generate:examples && npm run test:e2e && npm run test:proxy-e2e"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "axios": "^1.7.9",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "eventsource-parser": "^3.0.6",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "jmespath": "^0.16.0",
    "lodash": "^4.17.23",
    "openapi-types": "^12.1.3",
    "ora": "^5.4.1",
    "pinyin-pro": "^3.28.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/axios-mock-adapter": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/jmespath": "^0.15.2",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22.0.0",
    "axios-mock-adapter": "^2.1.0",
    "copyfiles": "^2.4.1",
    "express": "^4.21.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
