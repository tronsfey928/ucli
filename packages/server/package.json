{
  "name": "@tronsfey/ucli-server",
  "version": "0.6.4",
  "description": "ucli server — centralized OpenAPI and MCP management server with multi-database support",
  "keywords": ["openapi", "oas", "gateway", "nestjs", "jwt", "api-management"],
  "license": "MIT",
  "engines": { "node": ">=18" },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**",
    "assets/**",
    "README.md",
    "README.zh.md"
  ],
  "bin": {
    "ucli-server": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "build:full": "pnpm --filter @tronsfey/ucli-admin build && tsc -p tsconfig.json && rm -rf dist/admin-ui && cp -r ../admin/dist ./dist/admin-ui",
    "prepack": "pnpm --filter @tronsfey/ucli-admin build && tsc -p tsconfig.json && rm -rf dist/admin-ui && cp -r ../admin/dist ./dist/admin-ui",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "test": "jest --config jest.config.js",
    "test:e2e": "jest --config jest-e2e.config.js",
    "test:coverage": "jest --config jest.config.js --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^5.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "joi": "^17.13.3",
    "jose": "^5.10.0",
    "mysql2": "^3.14.0",
    "nestjs-pino": "^4.3.0",
    "pg": "^8.13.3",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.21",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
