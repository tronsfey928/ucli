{
  "name": "@tronsfey/ucli",
  "version": "0.4.2",
  "description": "ucli — proxy OpenAPI and MCP services for AI agents",
  "keywords": [
    "openapi",
    "oas",
    "cli",
    "ai-agent",
    "api-client"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**",
    "assets/**",
    "skill.md",
    "README.md",
    "README.zh.md"
  ],
  "type": "module",
  "bin": {
    "ucli": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup && chmod +x dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tronsfey/openapi2cli": "1.0.13",
    "axios": "^1.8.4",
    "commander": "^12.1.0",
    "conf": "^13.1.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "2026.1.14",
    "@tronsfey/mcp2cli": "1.0.1",
    "@types/node": "^22.14.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
