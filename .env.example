# Root-level env example — copy to packages/server/.env and fill in values.
# See packages/server/.env.example for the full reference.

# Quick local dev (memory adapters, no DB/Redis required):
# cd packages/server && cp .env.example .env && pnpm dev

# Production with docker-compose infra:
# DATABASE_URL=postgresql://oas_gateway:changeme@localhost:5432/oas_gateway
# REDIS_URL=redis://:changeme@localhost:6379
# STORAGE_TYPE=postgres
# CACHE_TYPE=redis
